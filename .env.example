# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here

# RabbitMQ Configuration (External MQ Service)
# Update these values to match your external RabbitMQ setup
RABBITMQ_URL=amqp://username:password@your-rabbitmq-host:5672/
# Alternative format for different setups:
# RABBITMQ_URL=amqp://guest:guest@localhost:5672/
# RABBITMQ_URL=amqp://admin:admin123@rabbitmq.example.com:5672/vhost

# Vector Store Configuration
CHROMA_PERSIST_DIRECTORY=./chroma_db

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Logging Configuration
LOG_LEVEL=INFO