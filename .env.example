# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here

# RabbitMQ Configuration (External MQ Service)
# Update these values to match your external RabbitMQ setup
RABBITMQ_URL=amqp://username:password@your-rabbitmq-host:5672/
# Alternative format for different setups:
# RABBITMQ_URL=amqp://guest:guest@localhost:5672/
# RABBITMQ_URL=amqp://admin:admin123@rabbitmq.example.com:5672/vhost

# Vector Store Configuration (Qdrant)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
CHROMA_PERSIST_DIRECTORY=./chroma_db

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Access Control Configuration
# Set to true to disable all metadata filtering and access control
# WARNING: This will allow access to ALL knowledge regardless of tenant/role restrictions
NO_FILTER=false

# Logging Configuration
LOG_LEVEL=INFO